# Copy this file to .env and edit before running `docker compose up`.

# The folder on your actual machine that you want the backend to be able to
# scan. It gets mounted read-only into the backend container at /data — so
# when scanning from the app, use paths like /data/Photos, not your real
# Windows/Mac path (the container can't see your OS's filesystem directly).
#
# Windows example: SCAN_MOUNT=C:/Users/you
# Mac/Linux example: SCAN_MOUNT=/home/you
SCAN_MOUNT=./
